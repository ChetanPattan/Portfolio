@page "/"
@inject IJSRuntime JS

<PageTitle>Chetan Pattan | .NET Backend &amp; API Engineer</PageTitle>

<!-- ===================== HERO ===================== -->
<section class="hero">
    <div class="container">
        <div>
            <div class="hero-badge"><span class="dot"></span> Open to opportunities</div>
            <h1>
                <span id="heroName"></span><span class="type-cursor"></span>
                <span class="role"><span id="heroRole"></span></span>
            </h1>
            <p class="hero-lede">
                Specializing in banking and fintech backends, I have engineered enterprise Loan Origination Systems (LOS) and am currently building Loan Management Systems (LMS), secure APIs, and critical third-party integrations.
            </p>
            <div class="hero-actions">
                <a class="btn btn-primary" href="resume/ChetanPattan_Resume.pdf" target="_blank">
                    ↓ Download Resume
                </a>
                <a class="btn btn-ghost" href="#contact">Get in touch</a>
            </div>
            <div class="hero-meta">
                <div><strong><span data-count-to="3" data-count-suffix="+">0+</span> yrs</strong>professional experience</div>
                <div><strong><span data-count-to="10" data-count-suffix="+">0+</span></strong>third-party API integrations</div>
                <div><strong>Banking</strong>&amp; fintech domain</div>
            </div>
        </div>

        <!-- Signature element: the resume, served as an API. Each tab is a
             real slice of the actual resume (profile, auth/security work,
             and the LOS/LMS webhook integrations). -->
        <div class="console-card">
            <div class="console-bar">
                <span class="console-dot"></span>
                <span class="console-dot"></span>
                <span class="console-dot"></span>
                <span class="console-title">chetan-api.v1 — interactive session</span>
            </div>
            <div class="console-tabs" id="consoleTabs">
                <button class="console-tab active" data-tab="0">GET /profile</button>
                <button class="console-tab" data-tab="1">POST /security</button>
                <button class="console-tab" data-tab="2">POST /integrations</button>
            </div>
            <div class="console-body">
                <div class="req" id="consoleReq"></div>
                <pre id="consoleJson"></pre>
                <div class="console-status"><span class="dot"></span> <span id="consoleStatus"></span></div>
            </div>
        </div>
    </div>
</section>

<!-- ===================== ABOUT ===================== -->
<section class="section" id="about">
    <div class="container">
        <div class="section-head reveal">
            <div class="section-tag"><span class="tag-bracket">{ 01 }</span> About</div>
            <h2>Backend engineering, banking-grade</h2>
        </div>
        <div class="about-grid">
            <div class="reveal">
                <p>
                    I'm a software engineer specializing in <strong style="color:#fff">.NET, ASP.NET Core Web API,
                    ASP.NET MVC and Laravel</strong>, currently building enterprise Loan Origination (LOS) and Loan
                    Management (LMS) systems for a subsidiary of State Bank of India.
                </p>
                <p>
                    My day-to-day is integrating third-party financial APIs, securing endpoints with JWT
                    authentication and RSA encryption, automating recurring operations with schedulers, and
                    keeping production banking systems scalable and maintainable.
                </p>
                <p>
                    I hold an M.Sc. in Computer Science from Ramnarain Ruia Autonomous College, Mumbai, and a
                    B.Sc. in Computer Science from Ramniranjan Jhunjhunwala College, Mumbai.
                </p>
            </div>
            <ul class="highlight-list reveal">
                <li>Banking &amp; fintech domain experience across LOS/LMS platforms</li>
                <li>Secure API integrations: Karza, Accumn, CRIF, Cygnet, Doqfy, YONO Banking, SBI Payments</li>
                <li>Authentication, encryption, automation &amp; IP-whitelisting expertise</li>
                <li>Hands-on with production support, enhancements &amp; scalable deployments</li>
                <li>Comfortable in client-facing and stakeholder coordination roles</li>
            </ul>
        </div>
    </div>
</section>

